# Backend (Spring Boot)
MONGO_HOST=localhost
MONGO_PORT=27017
MONGO_DB=agrismart
JWT_SECRET=change-me-please-32-chars-minimum
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MS=86400000
JWT_REFRESH_EXPIRATION_MS=604800000
CORS_ALLOWED_ORIGINS=http://localhost:4200
PUBLIC_BASE_URL=http://localhost:8080
UPLOAD_DIR=uploads
GOOGLE_CLIENT_ID=
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_AUTH=true
SMTP_STARTTLS=true
SMTP_FROM=
LOG_LEVEL_ROOT=INFO
LOG_LEVEL_APP=INFO
LOG_LEVEL_MONGO=WARN
SEED_ADMIN_PASSWORD=admin123
SEED_DEFAULT_PASSWORD=Test@1234

# Chatbot (Flask)
CHATBOT_CORS_ORIGINS=http://localhost:4200
CHATBOT_ADMIN_TOKEN=
CHATBOT_REQUIRE_ADMIN_TOKEN=true
CHATBOT_REQUIRE_AUTH_TOKEN=true
CHATBOT_LOG_LEVEL=INFO
CHATBOT_DEBUG_DEFAULT=false
SPRING_API_BASE_URL=http://localhost:8080
# Keep at least one provider key to enable LLM responses.
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
CHATBOT_MEMORY_TURNS=4
CHATBOT_MIN_CONFIDENCE=0.45
CHATBOT_MAX_USER_AGENTS=800
CHATBOT_USER_AGENT_TTL=3600
CHATBOT_EMBEDDINGS_MODEL=sentence-transformers/all-MiniLM-L6-v2
CHATBOT_EMBEDDINGS_MIN_SCORE=0.38
CHATBOT_INTENT_SEMANTIC_THRESHOLD=0.55
CHATBOT_MAX_MESSAGE_CHARS=1200

# Frontend (Angular)
# Update agrismart-web/src/environments/environment*.ts for API URLs and OAuth client IDs.

# API Gateway
GATEWAY_PORT=8081
GATEWAY_CORS_ORIGINS=http://localhost:4200
SPRING_API_URL=http://localhost:8080
CHATBOT_API_URL=http://localhost:5002
GATEWAY_RATE_LIMIT_PER_MIN=120
